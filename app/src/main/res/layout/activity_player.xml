<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/player_bg">

    <!-- Player View -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:show_timeout="3000"
        app:surface_type="texture_view"
        app:use_controller="false"
        app:resize_mode="fit"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/player_first_frame_scrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/player_bg"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Playback error HUD overlay -->
    <LinearLayout
        android:id="@+id/player_error_hud"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="@color/player_bg"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_error_outline"
            android:layout_marginBottom="16dp"
            android:importantForAccessibility="no"
            app:tint="@color/player_icon" />

        <TextView
            android:id="@+id/tv_error_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/player_title_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_error_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/player_text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <LinearLayout
            android:id="@+id/error_action_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_gravity="center_horizontal">

            <Button
                android:id="@+id/btn_error_soft_decode"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/player_icon"
                android:text="@string/player_error_action_soft_decode"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_error_retry"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/player_icon"
                android:text="@string/player_error_action_retry"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_error_copy_diag"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/player_icon"
                android:text="@string/player_error_action_copy_diag"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_error_back"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/player_icon"
                android:text="@string/player_error_action_back"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Gesture overlay -->
    <View
        android:id="@+id/gesture_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Custom controls -->
    <include
        layout="@layout/player_controls"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Brightness indicator (left side) -->
    <LinearLayout
        android:id="@+id/brightness_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="0dp"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:layout_marginStart="14dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.38">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_brightness"
            app:tint="@color/player_icon" />

        <ProgressBar
            android:id="@+id/brightness_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="4dp"
            android:layout_height="170dp"
            android:layout_marginTop="16dp"
            android:progressDrawable="@drawable/progress_land_brightness_vertical"
            android:max="100" />

    </LinearLayout>

    <!-- Volume indicator (right side) -->
    <LinearLayout
        android:id="@+id/volume_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="0dp"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:layout_marginEnd="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.38">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_volume"
            android:importantForAccessibility="no"
            app:tint="@color/player_icon" />

        <ProgressBar
            android:id="@+id/volume_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="4dp"
            android:layout_height="170dp"
            android:layout_marginTop="16dp"
            android:progressDrawable="@drawable/progress_land_brightness_vertical"
            android:max="100" />

    </LinearLayout>

    <!-- Seek indicator (center) -->
    <TextView
        android:id="@+id/seek_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_elevated_card_strong"
        android:padding="@dimen/ov_space_md"
        android:textColor="@color/player_title_primary"
        android:textSize="@dimen/ov_text_body"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle display -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="100dp"
        android:background="@drawable/bg_elevated_card_strong"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
