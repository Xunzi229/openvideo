<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="播放速度"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rg_speed_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_speed_0_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.5x" />

                <RadioButton
                    android:id="@+id/rb_speed_0_75"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.75x" />

                <RadioButton
                    android:id="@+id/rb_speed_1_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.0x" />

                <RadioButton
                    android:id="@+id/rb_speed_1_25"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.25x" />

                <RadioButton
                    android:id="@+id/rb_speed_1_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.5x" />

                <RadioButton
                    android:id="@+id/rb_speed_2_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.0x" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="循环模式"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_loop_value"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:text="循环"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_playback_end_behavior"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_playback_end_value"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:text="@string/settings_playback_end_follow"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="快进/快退间隔"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_seek_value"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:text="10s"
                android:background="?attr/selectableItemBackground" />

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_remember"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="记住播放进度" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_hw_accel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="硬件加速" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_pause_on_exit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="退出时暂停" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_auto_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="自动播放下一个" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/sw_bg_audio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_bg_audio" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>