<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_root"
    android:clipToPadding="false"
    android:paddingHorizontal="56dp"
    android:paddingTop="40dp"
    android:paddingBottom="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_home_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tv_home_title"
            android:textColor="@color/ov_text_primary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_home_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/tv_home_subtitle"
            android:textColor="@color/ov_text_secondary"
            android:textSize="18sp" />

        <LinearLayout
            android:id="@+id/tv_permission_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_elevated_card_strong"
            android:clickable="true"
            android:contentDescription="@string/tv_permission_title"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:foreground="@drawable/bg_focusable_card"
            android:minHeight="96dp"
            android:nextFocusUp="@id/tv_permission_panel"
            android:nextFocusLeft="@id/tv_permission_panel"
            android:nextFocusRight="@id/tv_permission_panel"
            android:nextFocusDown="@id/tv_card_continue"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tv_permission_title"
                android:textColor="@color/player_title_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/tv_permission_desc"
                android:textColor="@color/player_title_normal"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/tv_permission_action"
                android:textColor="@color/ov_accent_blue"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tv_card_continue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_elevated_card_strong"
                android:clickable="true"
                android:contentDescription="@string/tv_home_continue"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:foreground="@drawable/bg_focusable_card"
                android:minHeight="112dp"
                android:nextFocusUp="@id/tv_permission_panel"
                android:nextFocusLeft="@id/tv_card_continue"
                android:nextFocusRight="@id/tv_card_folders"
                android:nextFocusDown="@id/tv_card_series"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/tv_home_continue_cover"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:background="@color/player_panel_border"
                    android:contentDescription="@string/tv_home_continue"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_play" />

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="14dp"
                    android:contentDescription="@string/tv_home_continue"
                    android:src="@drawable/ic_play"
                    app:tint="@color/player_title_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/tv_home_continue"
                    android:textColor="@color/player_title_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_home_continue_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/tv_home_continue_desc"
                    android:textColor="@color/player_title_normal"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tv_card_folders"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:background="@drawable/bg_elevated_card_strong"
                android:clickable="true"
                android:contentDescription="@string/tv_home_folders"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:foreground="@drawable/bg_focusable_card"
                android:minHeight="112dp"
                android:nextFocusUp="@id/tv_card_folders"
                android:nextFocusLeft="@id/tv_card_continue"
                android:nextFocusRight="@id/tv_card_folders"
                android:nextFocusDown="@id/tv_card_sources"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/tv_home_folders_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@string/tv_home_folders"
                    android:src="@drawable/ic_folder"
                    app:tint="@color/player_title_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/tv_home_folders"
                    android:textColor="@color/player_title_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_home_folders_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/tv_home_folders_desc"
                    android:textColor="@color/player_title_normal"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tv_card_series"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_elevated_card_strong"
                android:clickable="true"
                android:contentDescription="@string/tv_home_series"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:foreground="@drawable/bg_focusable_card"
                android:minHeight="112dp"
                android:nextFocusUp="@id/tv_card_continue"
                android:nextFocusLeft="@id/tv_card_series"
                android:nextFocusRight="@id/tv_card_sources"
                android:nextFocusDown="@id/tv_card_series"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/tv_home_series_cover"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:background="@color/player_panel_border"
                    android:contentDescription="@string/tv_home_series"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_movie" />

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="14dp"
                    android:contentDescription="@string/tv_home_series"
                    android:src="@drawable/ic_list"
                    app:tint="@color/player_title_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/tv_home_series"
                    android:textColor="@color/player_title_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_home_series_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/tv_home_series_desc"
                    android:textColor="@color/player_title_normal"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tv_card_sources"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:background="@drawable/bg_elevated_card_strong"
                android:clickable="true"
                android:contentDescription="@string/tv_home_sources"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:foreground="@drawable/bg_focusable_card"
                android:minHeight="112dp"
                android:nextFocusUp="@id/tv_card_folders"
                android:nextFocusLeft="@id/tv_card_series"
                android:nextFocusRight="@id/tv_card_settings"
                android:nextFocusDown="@id/tv_card_sources"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/tv_home_sources_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@string/tv_home_sources"
                    android:src="@drawable/ic_home"
                    app:tint="@color/player_title_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/tv_home_sources"
                    android:textColor="@color/player_title_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_home_sources_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/tv_home_sources_desc"
                    android:textColor="@color/player_title_normal"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tv_card_settings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:background="@drawable/bg_elevated_card_strong"
                android:clickable="true"
                android:contentDescription="@string/tv_home_settings"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:foreground="@drawable/bg_focusable_card"
                android:minHeight="112dp"
                android:nextFocusUp="@id/tv_card_folders"
                android:nextFocusLeft="@id/tv_card_sources"
                android:nextFocusRight="@id/tv_card_settings"
                android:nextFocusDown="@id/tv_card_settings"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/tv_home_settings_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@string/tv_home_settings"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/player_title_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/tv_home_settings"
                    android:textColor="@color/player_title_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_home_settings_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/tv_home_settings_desc"
                    android:textColor="@color/player_title_normal"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
