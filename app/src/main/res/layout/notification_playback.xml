<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="4dp"
    android:paddingEnd="12dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/notification_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/playback_notification_title"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notification_status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/playback_notification_status"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/notification_transport_row"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:gravity="center_horizontal|center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_previous"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="@string/playback_notification_previous"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_skip_previous"
            android:tint="@color/playback_notification_icon" />

        <ImageView
            android:id="@+id/btn_play_pause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            android:contentDescription="@string/playback_notification_pause"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_pause"
            android:tint="@color/playback_notification_icon" />

        <ImageView
            android:id="@+id/btn_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="@string/playback_notification_next"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_skip_next"
            android:tint="@color/playback_notification_icon" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/notification_progress_row"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/notification_time_elapsed"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textColor="@color/playback_notification_status"
            android:textSize="11sp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1">

            <ProgressBar
                android:id="@+id/notification_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_gravity="center_vertical"
                android:max="1000"
                android:progressDrawable="@drawable/notification_playback_progress" />

            <LinearLayout
                android:id="@+id/notification_seek_zones"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView android:id="@+id/seek_zone_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_10" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
                <TextView android:id="@+id/seek_zone_11" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/notification_time_duration"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="@color/playback_notification_status"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
