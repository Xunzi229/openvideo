<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/ov_bg_elevated_strong"
    android:orientation="vertical"
    android:padding="@dimen/ov_space_lg">

    <TextView
        android:id="@+id/option_play"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/ov_space_md"
        android:text="播放"
        android:textColor="@color/ov_text_primary"
        android:textSize="@dimen/ov_text_body" />

    <TextView
        android:id="@+id/option_favorite"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/ov_space_md"
        android:text="收藏"
        android:textColor="@color/ov_text_primary"
        android:textSize="@dimen/ov_text_body" />

    <TextView
        android:id="@+id/option_add_to_playlist"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/ov_space_md"
        android:text="@string/option_add_to_playlist"
        android:textColor="@color/ov_text_primary"
        android:textSize="@dimen/ov_text_body" />

    <TextView
        android:id="@+id/option_details"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/ov_space_md"
        android:text="查看详情"
        android:textColor="@color/ov_text_primary"
        android:textSize="@dimen/ov_text_body" />

    <TextView
        android:id="@+id/option_share"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/ov_space_md"
        android:text="分享"
        android:textColor="@color/ov_text_primary"
        android:textSize="@dimen/ov_text_body" />

    <TextView
        android:id="@+id/option_delete"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/ov_space_md"
        android:text="删除"
        android:textColor="@color/ov_accent_blue"
        android:textSize="@dimen/ov_text_body" />

</LinearLayout>
