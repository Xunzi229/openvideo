<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_root"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:text="@string/settings_page_title"
            android:textColor="@color/ov_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- General Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:text="@string/settings_section_general"
            android:textColor="@color/ov_accent_blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Theme -->
        <LinearLayout
            android:id="@+id/row_theme"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_theme"
                android:textColor="@color/ov_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_theme_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_theme_system"
                android:textColor="@color/ov_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="16dp"
            android:background="@color/ov_divider" />

        <!-- Language -->
        <LinearLayout
            android:id="@+id/row_language"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_language"
                android:textColor="@color/ov_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_language_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_language_system"
                android:textColor="@color/ov_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ov_divider" />

        <!-- Player Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:text="@string/settings_section_player"
            android:textColor="@color/ov_accent_blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Default Aspect Ratio -->
        <LinearLayout
            android:id="@+id/row_default_ratio"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_default_ratio"
                android:textColor="@color/ov_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_ratio_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_ratio_default"
                android:textColor="@color/ov_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="16dp"
            android:background="@color/ov_divider" />

        <!-- Default Speed -->
        <LinearLayout
            android:id="@+id/row_default_speed"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_default_speed"
                android:textColor="@color/ov_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_speed_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0x"
                android:textColor="@color/ov_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ov_divider" />

        <!-- Storage Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:text="@string/settings_section_storage"
            android:textColor="@color/ov_accent_blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Clear Thumbnail Cache -->
        <LinearLayout
            android:id="@+id/row_clear_cache"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_clear_cache"
                android:textColor="@color/ov_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_cache_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 MB"
                android:textColor="@color/ov_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="16dp"
            android:background="@color/ov_divider" />

        <!-- Clear History -->
        <LinearLayout
            android:id="@+id/row_clear_history"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_clear_history"
                android:textColor="@color/ov_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_history_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/ov_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ov_divider" />

        <!-- About Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:text="@string/settings_section_about"
            android:textColor="@color/ov_accent_blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Version -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_version"
                android:textColor="@color/ov_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0.0"
                android:textColor="@color/ov_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginStart="16dp"
            android:background="@color/ov_divider" />

        <!-- Open Source License -->
        <LinearLayout
            android:id="@+id/row_license"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_license"
                android:textColor="@color/ov_text_primary"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
