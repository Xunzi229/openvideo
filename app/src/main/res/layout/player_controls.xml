<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/controls_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/top_scrim"
        android:layout_width="0dp"
        android:layout_height="112dp"
        android:background="@drawable/bg_player_top_scrim"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bottom_scrim"
        android:layout_width="0dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_player_bottom_scrim"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="@dimen/ov_space_xl"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="@dimen/ov_space_xl"
        android:background="@drawable/bg_player_control_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_player_touch"
            android:contentDescription="@string/player_action_back"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/player_icon" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/ov_space_md"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/player_title_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_player_control_bar"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_network_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_land_resolution_badge"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:text="@string/player_network_status_buffering"
            android:textColor="@color/player_title_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/progress_row"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/player_title_primary"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="@dimen/ov_space_md"
                android:layout_weight="1"
                android:progressTint="@color/player_accent"
                android:progressBackgroundTint="#55B4BDCA"
                android:thumbTint="@color/player_icon" />

            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="00:00"
                android:textColor="@color/player_title_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/playback_controls"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_player_touch"
                android:contentDescription="@string/player_action_previous"
                android:src="@drawable/ic_skip_previous"
                app:tint="@color/player_icon" />

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginHorizontal="22dp"
                android:background="@drawable/bg_player_primary_button"
                android:contentDescription="@string/player_action_play"
                android:src="@drawable/ic_play"
                app:tint="@color/player_icon" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_player_touch"
                android:contentDescription="@string/player_action_next"
                android:src="@drawable/ic_skip_next"
                app:tint="@color/player_icon" />
        </LinearLayout>

        <!-- Portrait tool row: speed, quality, episodes, subtitles, more. -->
        <LinearLayout
            android:id="@+id/tool_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:weightSum="5">

            <LinearLayout
                android:id="@+id/portrait_btn_speed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_player_touch"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_movie"
                    app:tint="@color/player_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_speed"
                    android:textColor="@color/player_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/portrait_btn_quality"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_player_touch"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_audio_track"
                    app:tint="@color/player_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_audio"
                    android:textColor="@color/player_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/portrait_btn_episodes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_player_touch"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_playlist"
                    app:tint="@color/player_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_episodes"
                    android:textColor="@color/player_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/portrait_btn_subtitles"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_player_touch"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_subtitles"
                    app:tint="@color/player_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_subtitles"
                    android:textColor="@color/player_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/portrait_btn_more"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_player_touch"
                android:clickable="true"
                android:contentDescription="@string/player_portrait_more"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_more_vert"
                    app:tint="@color/player_icon" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_more"
                    android:textColor="@color/player_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_lock"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="18dp"
        android:background="@drawable/bg_player_lock_button"
        android:contentDescription="@string/player_action_lock"
        android:src="@drawable/ic_lock"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/player_icon" />

    <ImageButton
        android:id="@+id/btn_fullscreen"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_player_lock_button"
        android:contentDescription="@string/player_action_fullscreen"
        android:src="@drawable/ic_fullscreen"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/player_icon" />

    <!-- Seek Thumbnail Preview MVP -->
    <FrameLayout
        android:id="@+id/seek_thumbnail_container"
        android:layout_width="160dp"
        android:layout_height="110dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_elevated_card_strong"
        android:padding="2dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_panel"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/seek_thumbnail_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:importantForAccessibility="no"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/seek_thumbnail_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="4dp"
            android:background="#99000000"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@android:color/white"
            android:textSize="12sp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
