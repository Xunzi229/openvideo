<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/controls_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/top_scrim"
        android:layout_width="0dp"
        android:layout_height="112dp"
        android:background="@drawable/bg_player_top_scrim"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bottom_scrim"
        android:layout_width="0dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_player_bottom_scrim"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="@dimen/ov_space_xl"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="@dimen/ov_space_xl"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/player_action_back"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/ov_text_primary" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/ov_space_md"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/ov_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/progress_row"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/ov_text_primary"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="@dimen/ov_space_md"
                android:layout_weight="1"
                android:progressTint="@color/ov_accent_blue"
                android:progressBackgroundTint="#55B4BDCA"
                android:thumbTint="@color/ov_text_primary" />

            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="00:00"
                android:textColor="@color/ov_text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/playback_controls"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_action_previous"
                android:src="@drawable/ic_skip_previous"
                app:tint="@color/ov_text_primary" />

            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginHorizontal="22dp"
                android:background="@drawable/bg_player_primary_button"
                android:contentDescription="@string/player_action_play"
                android:src="@drawable/ic_play"
                app:tint="@color/ov_text_primary" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_action_next"
                android:src="@drawable/ic_skip_next"
                app:tint="@color/ov_text_primary" />
        </LinearLayout>

        <!-- 竖屏稿：底栏五入口；「更多」即原播放器设置 -->
        <LinearLayout
            android:id="@+id/tool_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:weightSum="5">

            <LinearLayout
                android:id="@+id/portrait_btn_speed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_movie"
                    app:tint="@color/ov_text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_speed"
                    android:textColor="@color/ov_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/portrait_btn_quality"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_aspect_ratio"
                    app:tint="@color/ov_text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_quality"
                    android:textColor="@color/ov_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/portrait_btn_episodes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_playlist"
                    app:tint="@color/ov_text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_episodes"
                    android:textColor="@color/ov_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/portrait_btn_subtitles"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_subtitles"
                    app:tint="@color/ov_text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_subtitles"
                    android:textColor="@color/ov_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/portrait_btn_more"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/player_portrait_more"
                android:focusable="true"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_more_vert"
                    app:tint="@color/ov_text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_portrait_more"
                    android:textColor="@color/ov_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_lock"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="18dp"
        android:background="@drawable/bg_player_lock_button"
        android:contentDescription="@string/player_action_lock"
        android:src="@drawable/ic_lock"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/ov_text_secondary" />

    <ImageButton
        android:id="@+id/btn_fullscreen"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_player_lock_button"
        android:contentDescription="@string/player_action_fullscreen"
        android:src="@drawable/ic_fullscreen"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/ov_text_secondary" />

</androidx.constraintlayout.widget.ConstraintLayout>
