<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ov_bg_base"
    android:orientation="horizontal"
    android:padding="@dimen/ov_player_settings_padding">

    <LinearLayout
        android:layout_width="@dimen/ov_player_settings_nav_width"
        android:layout_height="match_parent"
        android:background="@color/ov_bg_elevated_strong"
        android:orientation="vertical"
        android:padding="@dimen/ov_space_md">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:text="@string/settings_title"
            android:textColor="@color/ov_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nav_playback"
            style="@style/Widget.OpenVideo.PlayerSettings.NavItem"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_settings_nav_selected"
            android:text="@string/settings_nav_playback"
            android:textColor="@color/ov_text_primary" />

        <TextView
            android:id="@+id/nav_video"
            style="@style/Widget.OpenVideo.PlayerSettings.NavItem"
            android:text="@string/settings_nav_video" />

        <TextView
            android:id="@+id/nav_audio"
            style="@style/Widget.OpenVideo.PlayerSettings.NavItem"
            android:text="@string/settings_nav_audio" />

        <TextView
            android:id="@+id/nav_subtitle"
            style="@style/Widget.OpenVideo.PlayerSettings.NavItem"
            android:text="@string/settings_nav_subtitle" />

        <TextView
            android:id="@+id/nav_gesture"
            style="@style/Widget.OpenVideo.PlayerSettings.NavItem"
            android:text="@string/settings_nav_gesture" />

        <TextView
            android:id="@+id/nav_other"
            style="@style/Widget.OpenVideo.PlayerSettings.NavItem"
            android:text="@string/settings_nav_other" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_reset_defaults"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:text="@string/settings_reset_defaults"
            android:textColor="@color/ov_accent_blue"
            android:textSize="15sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/ov_player_settings_padding"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/section_playback"
            style="@style/Widget.OpenVideo.PlayerSettings.Section">

            <LinearLayout style="@style/Widget.OpenVideo.PlayerSettings.Content">
                <TextView
                    style="@style/Widget.OpenVideo.PlayerSettings.GroupTitle"
                    android:text="@string/settings_group_play_control" />

                <TextView
                    style="@style/Widget.OpenVideo.PlayerSettings.RowTitle"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_playback_speed" />

                <RadioGroup
                    android:id="@+id/rg_speed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical">

                    <RadioButton android:id="@+id/rb_speed_0_5" style="@style/Widget.OpenVideo.PlayerSettings.Radio" android:text="@string/settings_speed_0_5" />
                    <RadioButton android:id="@+id/rb_speed_0_75" style="@style/Widget.OpenVideo.PlayerSettings.Radio" android:text="@string/settings_speed_0_75" />
                    <RadioButton android:id="@+id/rb_speed_1_0" style="@style/Widget.OpenVideo.PlayerSettings.Radio" android:text="@string/settings_speed_1_0" />
                    <RadioButton android:id="@+id/rb_speed_1_25" style="@style/Widget.OpenVideo.PlayerSettings.Radio" android:text="@string/settings_speed_1_25" />
                    <RadioButton android:id="@+id/rb_speed_1_5" style="@style/Widget.OpenVideo.PlayerSettings.Radio" android:text="@string/settings_speed_1_5" />
                    <RadioButton android:id="@+id/rb_speed_2_0" style="@style/Widget.OpenVideo.PlayerSettings.Radio" android:text="@string/settings_speed_2_0" />
                </RadioGroup>

                <include layout="@layout/player_settings_divider" />
                <include android:id="@+id/row_loop" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_skip" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_seek" layout="@layout/player_settings_row_value" />

                <TextView
                    style="@style/Widget.OpenVideo.PlayerSettings.GroupTitle"
                    android:layout_marginTop="14dp"
                    android:text="@string/settings_group_play_options" />

                <include android:id="@+id/row_remember" layout="@layout/player_settings_row_switch" />
                <include android:id="@+id/row_hw" layout="@layout/player_settings_row_switch" />
                <include android:id="@+id/row_pause" layout="@layout/player_settings_row_switch" />
                <include android:id="@+id/row_auto_next" layout="@layout/player_settings_row_switch" />
                <include android:id="@+id/row_bg_audio" layout="@layout/player_settings_row_switch" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/section_video"
            style="@style/Widget.OpenVideo.PlayerSettings.Section"
            android:visibility="gone">

            <LinearLayout style="@style/Widget.OpenVideo.PlayerSettings.Content">
                <TextView style="@style/Widget.OpenVideo.PlayerSettings.GroupTitle" android:text="@string/settings_group_display" />
                <include android:id="@+id/row_aspect" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_rotation" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_mirror" layout="@layout/player_settings_row_switch" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/section_audio"
            style="@style/Widget.OpenVideo.PlayerSettings.Section"
            android:visibility="gone">

            <LinearLayout style="@style/Widget.OpenVideo.PlayerSettings.Content">
                <TextView style="@style/Widget.OpenVideo.PlayerSettings.GroupTitle" android:text="@string/settings_group_audio" />
                <include android:id="@+id/row_pitch" layout="@layout/player_settings_row_switch" />
                <include android:id="@+id/row_boost" layout="@layout/player_settings_row_switch" />
                <include android:id="@+id/row_channel" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_delay" layout="@layout/player_settings_row_value" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/section_subtitle"
            style="@style/Widget.OpenVideo.PlayerSettings.Section"
            android:visibility="gone">

            <LinearLayout style="@style/Widget.OpenVideo.PlayerSettings.Content">
                <TextView style="@style/Widget.OpenVideo.PlayerSettings.GroupTitle" android:text="@string/settings_group_subtitle" />
                <include android:id="@+id/row_load_subtitle" layout="@layout/player_settings_row_action" />
                <include android:id="@+id/row_subtitle_size" layout="@layout/player_settings_row_seek" />
                <include android:id="@+id/row_subtitle_color" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_subtitle_bg" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_subtitle_position" layout="@layout/player_settings_row_seek" />
                <include android:id="@+id/row_subtitle_encoding" layout="@layout/player_settings_row_value" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/section_gesture"
            style="@style/Widget.OpenVideo.PlayerSettings.Section"
            android:visibility="gone">

            <LinearLayout style="@style/Widget.OpenVideo.PlayerSettings.Content">
                <TextView style="@style/Widget.OpenVideo.PlayerSettings.GroupTitle" android:text="@string/settings_group_gesture" />
                <include android:id="@+id/row_left_vertical" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_right_vertical" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_double_tap" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_long_press" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_horizontal" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_sensitivity" layout="@layout/player_settings_row_value" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/section_other"
            style="@style/Widget.OpenVideo.PlayerSettings.Section"
            android:visibility="gone">

            <LinearLayout style="@style/Widget.OpenVideo.PlayerSettings.Content">
                <TextView style="@style/Widget.OpenVideo.PlayerSettings.GroupTitle" android:text="@string/settings_group_other" />
                <include android:id="@+id/row_remember_other" layout="@layout/player_settings_row_switch" />
                <include android:id="@+id/row_auto_next_other" layout="@layout/player_settings_row_switch" />
                <include android:id="@+id/row_keep_screen" layout="@layout/player_settings_row_switch" />
                <include android:id="@+id/row_auto_hide" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_intro" layout="@layout/player_settings_row_value" />
                <include android:id="@+id/row_outro" layout="@layout/player_settings_row_value" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

</LinearLayout>
