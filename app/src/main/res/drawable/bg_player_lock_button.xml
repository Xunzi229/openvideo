<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="#334F8CFF" />
            <stroke
                android:width="1dp"
                android:color="@color/player_accent" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/player_panel_bg_soft" />
            <stroke
                android:width="1dp"
                android:color="@color/player_panel_border" />
        </shape>
    </item>
</selector>
