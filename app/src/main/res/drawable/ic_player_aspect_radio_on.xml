    <item
        android:bottom="7dp"
        android:left="7dp"
        android:right="7dp"
        android:top="7dp">
        <shape android:shape="oval">
            <solid android:color="@color/player_aspect_radio_dot" />
        </shape>
    </item>
</layer-list>
