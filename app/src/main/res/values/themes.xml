<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OpenVideo" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:statusBarColor">@color/ov_bg_base</item>
        <item name="android:navigationBarColor">@color/ov_bg_base</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.OpenVideo.Player" parent="Theme.OpenVideo">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/player_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Widget.OpenVideo.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">80dp</item>
        <item name="android:height">52dp</item>
        <item name="android:color">@color/ov_nav_active_indicator</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings" parent="" />

    <style name="Widget.OpenVideo.PlayerSettings.NavItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:textColor">@color/ov_text_secondary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.Section">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:fillViewport">false</item>
        <item name="android:scrollbarStyle">insideInset</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.Content">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/ov_bg_elevated_strong</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">18dp</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.GroupTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ov_text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.RowTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ov_text_primary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.Radio">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:textColor">@color/ov_text_primary</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>
