<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OpenVideo" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.OpenVideo.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.OpenVideo.MaterialAlertDialog</item>
        <item name="android:statusBarColor">@color/ov_bg_base</item>
        <item name="android:navigationBarColor">@color/ov_bg_base</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.OpenVideo.Player" parent="Theme.OpenVideo">
        <item name="colorPrimary">@color/player_accent</item>
        <item name="colorPrimaryVariant">@color/player_accent</item>
        <item name="colorOnPrimary">@color/player_title_primary</item>
        <item name="colorSecondary">@color/player_accent</item>
        <item name="android:colorBackground">@color/player_bg</item>
        <item name="colorSurface">@color/player_panel_bg</item>
        <item name="colorOnBackground">@color/player_title_primary</item>
        <item name="colorOnSurface">@color/player_title_primary</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.OpenVideo.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.OpenVideo.MaterialAlertDialog</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/player_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Widget.OpenVideo.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">0dp</item>
        <item name="android:height">0dp</item>
        <item name="android:color">@android:color/transparent</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings" parent="" />

    <style name="Widget.OpenVideo.PlayerSettings.NavItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/player_text_secondary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.Section">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:fillViewport">false</item>
        <item name="android:scrollbarStyle">insideInset</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.Content">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/player_panel_bg</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">18dp</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.GroupTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/player_text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.RowTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/player_title_normal</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.OpenVideo.PlayerSettings.Radio">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:textColor">@color/player_title_normal</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="ThemeOverlay.OpenVideo.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/ov_dialog_surface</item>
        <item name="colorOnSurface">@color/ov_text_primary</item>
        <item name="colorPrimary">@color/ov_accent_blue</item>
        <item name="android:colorAccent">@color/ov_accent_blue</item>
        <item name="android:backgroundDimAmount">0.58</item>
        <item name="scrimBackground">@color/ov_dialog_scrim</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.OpenVideo.Dialog</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.OpenVideo.Dialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.OpenVideo.Dialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.OpenVideo.Dialog.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.OpenVideo.Dialog.Button.Negative</item>
    </style>

    <style name="ShapeAppearance.OpenVideo.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="TextAppearance.OpenVideo.Dialog.Title" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/ov_text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.OpenVideo.Dialog.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/ov_text_secondary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.OpenVideo.Dialog.Button" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:minWidth">72dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textColor">@color/ov_accent_blue</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.OpenVideo.Dialog.Button.Positive" parent="Widget.OpenVideo.Dialog.Button" />

    <style name="Widget.OpenVideo.Dialog.Button.Negative" parent="Widget.OpenVideo.Dialog.Button">
        <item name="android:textColor">@color/ov_text_secondary</item>
    </style>
</resources>
